# Auto-detect text files and normalize to LF
* text=auto eol=lf

# Windows-specific scripts: keep CRLF (native to Windows)
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files: never touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.eot binary
*.ttf binary
*.otf binary
*.mp3 binary
*.mp4 binary
*.zip binary
*.tar.gz binary

